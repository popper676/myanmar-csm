# Server
PORT=15000
NODE_ENV=production

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:8888

# JWT Secrets (generate strong random strings for production)
JWT_SECRET=change-this-to-a-very-long-random-string-at-least-64-chars
JWT_REFRESH_SECRET=change-this-to-another-very-long-random-string-at-least-64-chars

# JWT Expiration
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Database
DB_PATH=./data/myanscm.db

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# File Upload
MAX_FILE_SIZE=5242880
UPLOAD_DIR=./uploads
